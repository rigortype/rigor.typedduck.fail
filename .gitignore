result
# The upstream reference pages are generated into the docs content root
# (sync-rigor-docs.mjs, flattened from the old reference/ namespace). Ignore
# everything at that root, then re-include only the hand-authored splash pages
# and the owned JA tree. New upstream top-level dirs/files are ignored
# automatically by the wildcard, so nothing generated is ever committed.
# (ja/chibirigor is re-excluded below.)
/src/content/docs/*
!/src/content/docs/index.mdx
!/src/content/docs/recently-updated.mdx
!/src/content/docs/ja/
src/data/rigor-release.json

# Generated by scripts/sync-chibirigor-docs.mjs from the upstream/chibirigor
# submodule — reproduced on every build (prebuild → sync:all), not committed.
# The EN edition (src/content/docs/chibirigor/) is already covered by the
# /src/content/docs/* rule above; the JA edition lives in the re-included ja/
# tree and so needs an explicit entry. Figures are copied per-locale.
src/content/docs/ja/chibirigor/
public/chibirigor/
public/ja/chibirigor/

# Generated by scripts/sync-playground.mjs from the upstream/rigor submodule
# (plugins/rigor-playground/wasm/index.html) — reproduced on every build.
public/playground/

# Cloudflare build logs occasionally land here when downloaded from the dashboard.
*.build.log

# Override any global .gitexclude that hides .claude/ — this repo
# ships shared Claude Code skills under .claude/skills/.
!.claude/
.claude/settings.local.json
