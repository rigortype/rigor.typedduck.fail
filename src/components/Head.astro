---
import Default from '@astrojs/starlight/components/Head.astro';
import { slugForId, NO_TWIN_IDS } from '../lib/docs';

const { entry } = Astro.locals.starlightRoute;

// Advertise this page's clean-markdown twin (see src/pages/[...slug].md.ts) so
// crawlers and LLM agents can fetch the Markdown directly. Skip the
// component-driven listings that have no twin.
const mdHref =
  typeof entry.id === 'string' && !NO_TWIN_IDS.has(entry.id)
    ? `/${slugForId(entry.id)}.md`
    : null;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: entry.data.title,
  author: {
    '@type': 'Person',
    name: 'Kenta Usami',
  },
  copyrightHolder: {
    '@type': 'Organization',
    name: 'TypedDuck',
  },
  copyrightYear: String(new Date().getFullYear()),
  copyrightNotice: "© 2026 TypedDuck. Licensed under CC BY-SA 4.0.",
  license: 'https://creativecommons.org/licenses/by-sa/4.0/',
};
---

<Default><slot /></Default>
{mdHref && <link rel="alternate" type="text/markdown" href={mdHref} />}
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
<script>
  import '../scripts/prompt-language';
</script>
