---
import release from '../data/rigor-release.json';

interface Props {
  lang?: 'en' | 'ja';
}

const { lang = 'en' } = Astro.props;
const tag = release.tag as string | null;
const date = release.date as string | null;

const formattedDate = date
  ? new Intl.DateTimeFormat(lang === 'ja' ? 'ja-JP' : 'en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    }).format(new Date(date))
  : null;

const isoDate = date ? date.slice(0, 10) : null;
const releaseUrl = tag ? `https://github.com/rigortype/rigor/releases/tag/${tag}` : null;

const label = lang === 'ja' ? '最新リリース' : 'Latest release';
---

{tag && (
  <p class="latest-release">
    <span class="latest-release__label">{label}</span>
    {releaseUrl ? (
      <a class="latest-release__tag" href={releaseUrl} rel="external">{tag}</a>
    ) : (
      <span class="latest-release__tag">{tag}</span>
    )}
    {formattedDate && (
      <>
        <span class="latest-release__sep" aria-hidden="true">·</span>
        <time class="latest-release__date" datetime={isoDate}>{formattedDate}</time>
      </>
    )}
  </p>
)}

<style>
  .latest-release {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0 0 1.5rem;
    padding: 0.4rem 0.85rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 999px;
    background: var(--sl-color-gray-6);
    font-size: var(--sl-text-sm);
    line-height: 1.4;
  }
  .latest-release__label {
    color: var(--sl-color-gray-2);
    font-weight: 600;
  }
  .latest-release__tag {
    font-family: var(--sl-font-mono);
    font-weight: 600;
    color: var(--sl-color-text-accent);
    text-decoration: none;
  }
  .latest-release__tag:hover {
    text-decoration: underline;
  }
  .latest-release__sep {
    color: var(--sl-color-gray-3);
  }
  .latest-release__date {
    color: var(--sl-color-gray-2);
  }
</style>
