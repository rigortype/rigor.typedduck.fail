---
interface Props {
  current: 'en' | 'ja';
}

const { current } = Astro.props;

const languages = [
  {
    code: 'en' as const,
    href: '/',
    name: 'English',
    description: 'Read in English',
    ariaLabel: 'Switch to English',
  },
  {
    code: 'ja' as const,
    href: '/ja/',
    name: '日本語',
    description: '日本語で読む',
    ariaLabel: '日本語に切り替える',
  },
];
---

<nav class="lang-chooser" aria-label={current === 'ja' ? '言語を選択' : 'Choose a language'}>
  {languages.map((lang) => {
    const isCurrent = lang.code === current;
    return (
      <a
        class:list={['lang-chooser__btn', { 'is-current': isCurrent }]}
        href={lang.href}
        hreflang={lang.code}
        lang={lang.code}
        aria-current={isCurrent ? 'page' : undefined}
        aria-label={isCurrent ? undefined : lang.ariaLabel}
      >
        <span class="lang-chooser__name">{lang.name}</span>
        <span class="lang-chooser__desc">{lang.description}</span>
      </a>
    );
  })}
</nav>

<style>
  .lang-chooser {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: 0.75rem;
    margin: 0 0 1.5rem;
    max-width: 36rem;
  }
  .lang-chooser__btn {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem 1.25rem;
    text-align: left;
    text-decoration: none;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0;                    /* Rigor: 0px on cards */
    background: var(--sl-color-bg);
    color: var(--sl-color-white);
    transition:
      background-color 120ms ease-out,
      border-color 120ms ease-out;
  }
  .lang-chooser__btn:hover {
    border-color: var(--sl-color-white);
    background: var(--sl-color-gray-6);
  }
  .lang-chooser__btn.is-current {
    border-color: var(--sl-color-text-accent);
    background: var(--sl-color-accent-low);
    cursor: default;
  }
  .lang-chooser__btn.is-current .lang-chooser__name {
    color: var(--sl-color-text-accent);
  }
  .lang-chooser__name {
    font-family: var(--sl-font-system);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.005em;
  }
  .lang-chooser__desc {
    font-family: var(--sl-font-mono);
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
    letter-spacing: 0.01em;
  }
</style>
